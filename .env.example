# Phase 3 operations
# Optional webhook receiver for trigger alerts (Slack webhook, custom endpoint, etc.)
ORCH_ALERT_WEBHOOK_URL=

# true -> orchestration trigger runs retraining action
# false -> detect + log + alert only (no retraining side effects)
ORCH_ENABLE_AUTO_RETRAIN=true

# Scheduler interval in seconds for `src.orchestration serve` (used when --interval 0)
ORCH_SCHEDULER_INTERVAL=300

# Scenario used by scheduler service
ORCH_SCENARIO=random_holdout

# Frontend runtime target (build arg for docker compose frontend service)
VITE_API_BASE_URL=http://localhost:8000
